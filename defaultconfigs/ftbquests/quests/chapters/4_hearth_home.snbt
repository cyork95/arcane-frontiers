				{id: "000E2003" type: "item" item: "copycats:copycat_panel" count: 4}
				{id: "000E2004" type: "xp" xp: 40}
			]
			title: "CopyCats+"
			icon: "copycats:copycat_panel"
			description: [
				"§6CopyCats+§f is one of the most powerful building mods in the pack."
				"§fIt lets you take the §etexture of any block§f and apply it to"
				"§fpure-geometry shapes — panels, slabs, stairs, frames, and more."
				""
				"§eCopyCat Panel:§r"
				"§7• §eCrafting:§7 §e4 Iron Bars§7 in a square (shapeless-ish, in crafting table)."
				"§7• §ePlace it§7 anywhere, then §eright-click with any block§7 to copy texture."
				"§7• The panel is now an ultra-thin decorative surface with that texture."
				""
				"§eWhy this is powerful:§r"
				"§7• §eCreate machinery§7 looks industrial — CopyCat Panels let you clad"
				"§7  the outside in §eCobblestone§7, §eGranite§7, or §eSpruce Planks§7 so"
				"§7  the factory blends into your build style."
				"§7• §eCopyCat Stairs§7 — stairs with any texture, including non-stair blocks."
				"§7• §eCopyCat Slab§7 — half-thickness, any texture."
				"§7• §eCopyCat Frame§7 — hollow border frame, great for windows."
				""
				"§eShapes available:§r"
				"§7• Panel (1/16 thick), Slab (8/16), Stairs, Step, Wall,"
				"§7  Board (quarter slab), Fence, Pane, and Frame."
				""
				"§eTip:§r"
				"§7• §eCopyCat Panel§7 on a §eMechanical Bearing§7 wall creates seamless"
				"§7  animated doors that look like solid stone. See Ch 2 bearings."
				""
				"§a► Craft and hold a CopyCat Panel."
			]
			dependencies: ["000E0001"]
		}

