			]
			title: "Twilight Lich — Boss 2/6"
			icon: "twilightforest:lich_trophy"
			description: [
				"§6The Twilight Lich§f is a powerful undead mage atop a §eLich Tower§f."
				"§fDefeating it unlocks the §eLabyrinth§f (Minoshroom)."
				""
				"§eFinding the Lich Tower:§r"
				"§7• Large gothic tower visible from across the forest."
				"§7• Check §eMagic Map§7 — Lich Towers appear after Naga is defeated."
				""
				"§eFight — three phases:§r"
				"§71. §ePhase 1§7 — three §eGolden Shields§7 orbit the Lich."
				"§7   Destroy all three shields before the Lich takes damage."
				"§7   §eShields are one-shot each§7 — any hit destroys them."
				"§72. §ePhase 2§7 — Lich teleports and summons zombie minions."
				"§7   Focus the Lich directly, ignore minions."
				"§73. §ePhase 3§7 — Lich fires ender pearls and shadow bolts rapidly."
				"§7   §eShield + dodge§7. Ars Nouveau Orbit + Shield covers all angles."
				""
				"§eDrops:§r"
				"§7• §eLich Trophy§7 — Ch 7.3 display."
				"§7• §eMagic Map Focus§7 — crafts Orb Maps that show boss locations."
				"§7• §eScepters§7 (random) — powerful wands, especially §eLifedrain Scepter§7."
				""
				"§a► Defeat the Twilight Lich and collect the Trophy."
			]
			dependencies: ["00120002"]
		}

