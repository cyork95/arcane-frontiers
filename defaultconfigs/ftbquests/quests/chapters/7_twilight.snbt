		{
			x: 0.0d
			y: 0.0d
			shape: "hexagon"
			id: "00120001"
			tasks: [{
				id: "00121001"
				type: "checkmark"
				title: "Build a Twilight Forest portal and enter the Twilight Forest dimension"
			}]
			rewards: [
				{id: "00122001" type: "item" item: "twilightforest:magic_map" count: 1}
				{id: "00122002" type: "xp" xp: 100}
			]
			title: "Twilight Portal"
			icon: "twilightforest:magic_map"
			subtitle: "A forest that never sees full daylight"
			description: [
				"§6The Twilight Forest§f is a dimension of eternal twilight —"
				"§fperpetual dusk, ancient trees, and six bosses arranged in a"
				"§flinear progression. Each boss unlocks the next."
				""
				"§ePrerequisite:§r"
				"§7• §6Dragon Slayer ✦§7 (Ch 3) confirmed — you have End-tier gear."
				"§7• §6Archmage Spellbook§7 recommended — Ars spells shine in TF."
				"§7• §6Tetra§7 upgraded weapons (Ch 2.7) — Brass and Andesite gear holds well."
				""
				"§eBuilding the portal:§r"
				"§71. §eDig a 2×2 hole§7 in the ground, 1 block deep."
				"§72. §eFill§7 the hole with §ewater§7."
				"§73. §eSurround§7the water with any §eflowers§7 (12 flowers for 2×2 pool)."
				"§74. §eThrow a§7 §eDiamond§7 into the water pool."
				"§75. The portal §eactivates§7 — lightning strikes the pool."
				"§76. §eEnter§7 the glowing vortex."
				""
				"§eMagic Map (reward):§r"
				"§7• §eRight-click§7 in the Twilight Forest → generates a map of the biomes."
				"§7• §eBoss locations§7 show as icons on the Magic Map."
				"§7• §eTreasure Map§7 (in TF chests) marks specific boss lairs."
				""
				"§a► Build the portal and enter. Mark done on arrival in the Twilight Forest."
			]
			dependencies: ["000D001C"]
		}

