			]
			title: "The Naga — Boss 1/6"
			icon: "twilightforest:naga_trophy"
			description: [
				"§6The Naga§f is the first Twilight Forest boss and the gate to all others."
				"§fDefeat it to unlock the §eLich Towers§f."
				""
				"§eFinding the Naga:§r"
				"§7• The Naga spawns in §eNaga Courtyards§7 — circular stone structures"
				"§7  in the §eForest§7 biome. Check your Magic Map for courtyard icons."
				""
				"§eFight strategy:§r"
				"§7• The Naga is a §elong serpent§7 — attack the §ehead§7 for damage."
				"§7• §eCircle the arena§7 — the Naga coils and charges in straight lines."
				"§7• §eArs Nouveau§7 Projectile + Harm + Amplify — hits the head for 10+ damage."
				"§7• §eBow§7 ranged fire from the courtyard wall is the safest approach."
				""
				"§eDrops:§r"
				"§7• §eNaga Trophy§7 — display in Trophy Room for Ch 7.3."
				"§7• §eNaga Scale§7 — crafting material for Naga Scale armor (high defense)."
				""
				"§a► Defeat the Naga and collect the Trophy."
			]
			dependencies: ["00120001"]
		}

