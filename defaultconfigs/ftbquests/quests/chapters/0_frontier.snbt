			rewards: [
				{id: "000A2005" type: "item" item: "minecraft:torch" count: 8}
			]
			title: "Know Your Recipes"
			icon: "minecraft:crafting_table"
			description: [
				"§6Just Enough Items (JEI)§f is the pack's recipe browser."
				"§fIt shows you how to make or use everything in all 66 mods."
				""
				"§eThe JEI panel:§r"
				"§7• Open your inventory (§eE§7). On the right side you will see a scrollable"
				"§7  list of every item in the pack. This is the JEI item browser."
				"§7• §eCtrl+F§7 or click the search bar at the bottom to search by name."
				""
				"§eCore hotkeys:§r"
				"§7• §eR§7 (hover item) = Show all crafting recipes for that item."
				"§7• §eU§7 (hover item) = Show all uses of that item in other recipes."
				"§7• §eA§7 (hover item) = Cheat-give in creative mode (admins only)."
				""
				"§eAdvanced tooltips:§r"
				"§7• Press §eF3+H§7 to toggle advanced tooltips on."
				"§7• Every item now shows its §6internal registry ID§7 at the bottom"
				"§7  (e.g. §ecreate:brass_ingot§7, §ears_nouveau:source_gem§7)."
				"§7• You need these IDs when editing SNBT quest files or KubeJS scripts."
				""
				"§eRecipe types to know:§r"
				"§7• §6Crafting Table§7 — standard recipes."
				"§7• §6Mechanical Mixer§7 — Create mixing recipes (Brass, Electrum, etc.)."
				"§7• §6Cooking Pot§7 — Farmer's Delight meals."
				"§7• §6Modular Workbench§7 — Tetra component assembly."
				"§7• §6Ritual§7 — Ars Nouveau ritual recipes."
				""
				"§a► Task: Hover any item and press R. When the recipe screen opens, mark done."
			]
			dependencies: ["000A0001"]
		}
