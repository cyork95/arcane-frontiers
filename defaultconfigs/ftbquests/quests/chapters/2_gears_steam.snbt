	quests: [

		// ============================================================
		// 2.1  FIRST ROTATION
		// ============================================================

		{
			x: 0.0d
			y: 0.0d
			shape: "hexagon"
			id: "000C0001"
			tasks: [{
				id: "000C1001"
				type: "item"
				item: "create:handbook"
				count: 1L
				consume_items: false
			}]
			rewards: [
				{id: "000C2001" type: "item" item: "create:andesite_alloy" count: 16}
				{id: "000C2002" type: "xp" xp: 25}
			]
			title: "The Kinetic Handbook"
			icon: "create:handbook"
			subtitle: "Your engineering education begins"
			description: [
				"§6Create§f is the technology system at the heart of this pack."
				"§fEverything is visual — you will watch your factory move in real time."
				""
				"§eGet the Create Handbook:§r"
				"§7Craft §e1 Book§7 at any crafting table → the Handbook appears."
				"§7It documents every Create block, recipe, and mechanic."
				"§7Press §eR§7 on any Create item in JEI to see its recipe."
				""
				"§eThe two numbers that drive everything:§r"
				"§7• §6RPM (Rotations Per Minute):§r speed of a kinetic network."
				"§7  Waterwheels give ~16 RPM. Windmills scale with sail count."
				"§7• §6SU (Stress Units):§r capacity of a kinetic network."
				"§7  Each source produces SU; each consumer costs SU."
				"§7  If consumers exceed producers, everything stalls."
				""
				"§eKey hotkeys:§r"
				"§7• §eRight-click§7 shaft blocks with a Wrench to adjust direction."
				"§7• §eHold Ctrl + right-click§7 a machine to see its stress cost in Jade."
				"§7• §eF3+H§7 shows internal registry IDs — useful when setting up quests."
				""
				"§7Pack SU cap note: §6Creative Motor§7 (Ch 5 reward) is capped at"
				"§7256 RPM / 512 SU. Use §ewindmills and the Ch 2.6 reactor§7 for real power."
				""
				"§a► Gate quest: completing this unlocks all Chapter 2 quests."
			]
			dependencies: []
		}

		{
			x: -8.0d
			y: 4.0d
			id: "000C0002"
			tasks: [{
				id: "000C1002"
				type: "checkmark"
				title: "A Windmill Bearing with 8+ Sail blocks is spinning and generating SU"
			}]
			rewards: [
				{id: "000C2003" type: "item" item: "create:cogwheel" count: 8}
				{id: "000C2004" type: "xp" xp: 20}
			]
			title: "First Windmill"
			icon: "create:sail_frame"
			description: [
				"§fA Windmill Bearing converts rotating sails into kinetic power."
				"§fMore sails = more SU. Minimum 8 sails for useful output."
				""
				"§eBuild sequence:§r"
				"§7  1. Craft a §6Windmill Bearing§7 and place it on the side of a block."
				"§7  2. Place §6Sail Frames§7 in a cross or plus shape attached to the Bearing."
				"§7  3. Right-click Sail Frames with wool to add sails (colour = aesthetic only)."
				"§7  4. Right-click the Bearing with a Wrench to start rotation."
				"§7  5. Attach a §6Shaft§7 extending from the Bearing's axis to distribute SU."
				""
				"§eSU output scaling:§r"
				"§7• 8 sails → ~32 SU (barely enough for one Mechanical Press)."
				"§7• 16 sails → ~64 SU (comfortable early base)."
				"§7• Build §e4 Windmills§7 early rather than one giant one — redundancy matters."
				""
				"§eWindmill placement tip:§r"
				"§7Windmills need open air on all sides to spin freely."
				"§7If another block is within the sail sweep radius, the bearing stalls."
				"§7Check with Jade — hover the Bearing to see if it reports stall."
				""
				"§a► Task: Checkmark when your Windmill is spinning and producing SU."
			]
			dependencies: ["000C0001"]
		}

		{
			x: -4.0d
			y: 4.0d
			id: "000C0003"
			tasks: [{
				id: "000C1003"
				type: "item"
				item: "create:water_wheel"
				count: 1L
				consume_items: false
			}]
			rewards: [
				{id: "000C2005" type: "item" item: "create:shaft" count: 4}
			]
			title: "Water Power"
			icon: "create:water_wheel"
			description: [
				"§fA Waterwheel mounted in flowing water is your most reliable early power"
				"§fsource — no sail management, no open-air requirements."
				""
				"§eBuild sequence:§r"
				"§7  1. Find or create a §eflowing water§7 channel (1–2 blocks wide)."
				"§7  2. Place the §6Water Wheel§7 block with its rotation axis perpendicular"
				"§7     to water flow. The wheel faces the water current direction."
				"§7  3. The wheel spins automatically in flowing water — no wrench needed."
				"§7  4. Attach a §6Shaft§7 to the wheel's axis to carry SU to your machines."
				""
				"§eOutput:§r"
				"§7• Standard Waterwheel: ~16 RPM, ~32 SU in flowing water."
				"§7• Large Waterwheel (Create 0.5+): higher SU — check JEI if available."
				"§7• §eStack multiple Waterwheels§7 on the same shaft for combined output."
				""
				"§eTip:§r §7Build your first base next to a river. Waterwheels + windmills"
				"§7= enough SU to run a Mechanical Press, Mixer, and early automation"
				"§7through the entire brass age before you need a boiler."
				""
				"§a► Task: Have a Water Wheel in your inventory. Not consumed."
			]
			dependencies: ["000C0001"]
		}

		{
			x: 0.0d
			y: 4.0d
			id: "000C0004"
			tasks: [{
				id: "000C1004"
				type: "item"
				item: "create:mechanical_press"
				count: 1L
				consume_items: false
			}]
			rewards: [
				{id: "000C2006" type: "item" item: "create:andesite_casing" count: 4}
				{id: "000C2007" type: "xp" xp: 25}
			]
			title: "Mechanical Press"
			icon: "create:mechanical_press"
			description: [
				"§fThe Mechanical Press is your first automated crafting machine."
				"§fIt presses items from above into items below — ore → ingot, ingot → sheet,"
				"§fandesite → Andesite Alloy, and dozens of other transformations."
				""
				"§eSetup:§r"
				"§7  1. Place the Mechanical Press above a §6Basin§7 (or a §6Belt§7 for"
				"§7     continuous item feeding)."
				"§7  2. Connect a §6Shaft§7 to the Press's side — it needs RPM to run."
				"§7  3. Drop items into the Basin or deliver them via a Funnel."
				"§7  4. The Press descends, presses the item, result stays in the Basin."
				""
				"§eKey early Press recipes:§r"
				"§7• §eAndesite Alloy:§7 Andesite + Iron Nugget → Andesite Alloy."
				"§7• §eIron Sheet:§7 Iron Ingot → Iron Sheet (for train tracks later)."
				"§7• §eCrushed Ore:§7 Raw Ore → Crushed Ore (×2 output vs smelting!)."
				""
				"§eTip:§r §7Put a §6Funnel§7 on the side of the Basin to auto-input items"
				"§7from a chest. Put another Funnel on the other side to auto-output"
				"§7results. The Press becomes fully automated from day one."
				""
				"§a► Task: Have a Mechanical Press in your inventory. Not consumed."
			]
			dependencies: ["000C0001"]
		}

		{
			x: 4.0d
			y: 4.0d
			id: "000C0005"
			tasks: [{
				id: "000C1005"
				type: "checkmark"
				title: "A Mechanical Drill is mounted on a moving Contraption"
			}]
			rewards: [
				{id: "000C2008" type: "item" item: "create:mechanical_drill" count: 2}
				{id: "000C2009" type: "xp" xp: 30}
			]
			title: "Drill for the Future"
			icon: "create:mechanical_drill"
			description: [
				"§fA Contraption is a collection of blocks that §omoves together§f —"
				"§fthe beating heart of Create's engineering. A Drill on a"
				"§fContraption is a mechanical miner that breaks blocks automatically."
				""
				"§eSimplest Contraption setup:§r"
				"§7  1. Craft a §6Mechanical Piston§7 and place it pointing into a wall."
				"§7  2. Attach a §6Mechanical Drill§7 to the front face of the Piston."
				"§7  3. Place a §6Piston Extension Pole§7 behind the Piston."
				"§7  4. Connect SU to the Piston via Shaft."
				"§7  5. The Piston extends, the Drill moves forward and mines everything"
				"§7     in its path — drops go to a chest via Funnel on the Piston."
				""
				"§eAlternative — Drill on a Cart Assembler:§r"
				"§7Attach the Drill to a §6Minecart§7 assembled into a contraption."
				"§7The cart drives down tracks, the Drill mines. Perfect for tunnel boring."
				""
				"§ePack tip:§r §7The §6Schematicannon§7 (JEI: search it) lets you save"
				"§7and paste contraption blueprints. Build a Drill contraption once,"
				"§7schematic it, and paste copies anywhere. Invaluable for mining arrays."
				""
				"§a► Task: Checkmark when a Mechanical Drill is mounted and moving."
			]
			dependencies: ["000C0004"]
		}

		{
			x: 8.0d
			y: 4.0d
			id: "000C0006"
			tasks: [{
				id: "000C1006"
				type: "item"
				item: "create:crushed_raw_iron"
				count: 8L
				consume_items: false
			}]
			rewards: [
				{id: "000C200A" type: "item" item: "create:crushed_raw_gold" count: 8}
				{id: "000C200B" type: "xp" xp: 35}
			]
			title: "Ore Doubling"
			icon: "create:crushed_raw_iron"
			description: [
				"§fCreate's ore processing chain produces §e2× the ingots§f from raw ore"
				"§fcompared to direct smelting. This alone makes a Create base permanently"
				"§fmore resource-efficient than any vanilla mine."
				""
				"§eThe crushing chain:§r"
				"§7  1. §6Millstone§7 (Andesite Alloy + Stone base) — slow, no power needed."
				"§7     Drop raw ore on top → crushed ore output. Starter option."
				"§7  2. §6Mechanical Crusher§7 (requires Crushing Wheels) — fast, needs SU."
				"§7     Feed raw ore in → crushed ore out at belt speed."
				"§7  3. Smelt or wash crushed ore → §e2× ingots§7 per raw ore block."
				""
				"§eWashing crushed ore (bonus output):§r"
				"§7Build an §6Encased Fan§7 facing a water source with crushed ore items"
				"§7flowing through the water stream — ores wash into extra drops"
				"§7(flint, clay, gold nuggets from iron ore, etc.)."
				"§7This is §eCh 2.2's 'Encased Fan'§7 quest — come back after Brass Age."
				""
				"§eTip:§r §7You only need 8 Crushed Iron Ore to complete this quest."
				"§7But set up the full chain — doubling all your ore output is fundamental"
				"§7to having enough Brass, Steel, and Zinc for the rest of Chapter 2."
				""
				"§a► Task: Have 8 Crushed Raw Iron in inventory. Not consumed."
				"§7(Crushed raw copper, gold, zinc also useful — crush those too.)"
			]
			dependencies: ["000C0004"]
		}

		// ============================================================
		// 2.2  THE BRASS AGE
		// ============================================================

		{
			x: 0.0d
			y: 8.0d
			id: "000C0007"
			tasks: [{
				id: "000C1007"
				type: "item"
				item: "create:mechanical_mixer"
				count: 1L
				consume_items: false
			}]
			rewards: [
				{id: "000C200C" type: "item" item: "create:basin" count: 2}
				{id: "000C200D" type: "xp" xp: 30}
			]
			title: "Build the Mixer"
			icon: "create:mechanical_mixer"
			description: [
				"§fThe Mechanical Mixer is Create's liquid and alloy crafting station."
				"§fYou cannot progress to Brass — or magic's Mage Spellbook — without it."
				""
				"§eRecipe:§r"
				"§7Craft the Mechanical Mixer from §6Andesite Alloy + Shafts + Iron Ingots§7."
				"§7(Exact recipe in JEI — search 'Mechanical Mixer'.)"
				""
				"§eSetup:§r"
				"§7  1. Place the §6Mechanical Mixer§7 above a §6Basin§7 (required — the Mixer"
				"§7     needs a Basin directly below it to function)."
				"§7  2. Connect a §6Shaft§7 to the Mixer's top — it needs at least 32 RPM."
				"§7  3. Deliver ingredients to the Basin via Funnels or manually."
				"§7  4. When all ingredients are in the Basin, the Mixer starts automatically."
				""
				"§eWhat the Mixer is used for:§r"
				"§7• §eBrass§7 (Copper + Zinc → Brass Ingots) — entire Brass Age."
				"§7• §eElectrum§7 (Gold + Silver → Electrum) — Create: New Age components."
				"§7• §ePotion mixing§7 (water + ingredients → splash potions for Wixie supply)."
				"§7• §eChocolate§7 (Cocoa + Sugar → for Farmer's Delight baking recipes)."
				""
				"§a► Task: Have a Mechanical Mixer in your inventory. Not consumed."
			]
			dependencies: ["000C0006"]
		}

		{
			x: -4.0d
			y: 12.0d
			id: "000C0008"
			tasks: [
				{
					id: "000C1008"
					type: "item"
					item: "minecraft:copper_ingot"
					count: 16L
					consume_items: false
				}
				{
					id: "000C1009"
					type: "item"
					item: "create:zinc_ingot"
					count: 16L
					consume_items: false
				}
			]
			rewards: [
				{id: "000C200E" type: "item" item: "create:crushed_raw_zinc" count: 8}
			]
			title: "Copper & Zinc"
			icon: "create:zinc_ingot"
			description: [
				"§fBrass requires two Create-relevant metals: §eCopper§f and §eZinc§f."
				"§fBoth generate naturally in the Overworld. Find them before the Mixer."
				""
				"§eCopper:§r"
				"§7• Generates as §6Copper Ore§7 at Y=48 and below (common)."
				"§7• Also common in §6YUNG's dungeons§7 and §6Lootr§7 chest loot."
				"§7• Crush raw Copper in the Millstone → Crushed Copper → smelt → ingots."
				"§7• With ore doubling: 1 Raw Copper → 2 Copper Ingots."
				""
				"§eZinc:§r"
				"§7• §6Create's Zinc Ore§7 generates at Y=10–70 (less common than copper)."
				"§7• Has a §6blueish-white§7 texture distinct from iron ore."
				"§7• Use §6Nature's Compass§7 + cave exploration for veins."
				"§7• Crush → smelt → Zinc Ingots using the same ore doubling chain."
				""
				"§eTip:§r §7Set up automated crushing for both ores before this quest."
				"§7You will need 32+ Brass Ingots for machines, tools, and the Mage Spellbook."
				"§7Stock up now rather than making repeated trips to the mine later."
				""
				"§a► Task: Have 16 Copper Ingots AND 16 Zinc Ingots. Neither consumed."
			]
			dependencies: ["000C0007"]
		}

		{
			x: 0.0d
			y: 12.0d
			id: "000C0009"
			tasks: [{
				id: "000C100A"
				type: "item"
				item: "create:brass_ingot"
				count: 16L
				consume_items: false
			}]
			rewards: [
				{id: "000C200F" type: "item" item: "create:brass_ingot" count: 16}
				{id: "000C2010" type: "xp" xp: 50}
			]
			title: "Mixing It Up"
			icon: "create:brass_ingot"
			description: [
				"§fBrass is the alloy that defines Create's mid-game. It is used in"
				"§fevery precision mechanism, every smart machine, every train component,"
				"§fand even the §6Mage Spellbook§7 upgrade in Chapter 1."
				""
				"§eMixing recipe:§r"
				"§7In the §6Mechanical Mixer + Basin§7 setup:"
				"§7  • Place §e1 Copper Ingot + 1 Zinc Ingot§7 in the Basin."
				"§7  • The Mixer blends them into §e1 Brass Ingot§7."
				"§7  • Run at §e32+ RPM§7 for reliable mixing speed."
				""
				"§eAutomating the Mixer:§r"
				"§7  1. Add §6Funnels§7 on both sides of the Basin — input and output."
				"§7  2. Feed §6Copper§7 from one chest and §6Zinc§7 from another via funnels."
				"§7  3. Output Brass to a §6Sophisticated Storage Chest§7 via output funnel."
				"§7  4. Set §6Smart Funnels§7 to filter — copper funnel only passes copper, etc."
				"§7  → The Mixer runs indefinitely, producing Brass without player input."
				""
				"§ePack note:§r §7The §6Mage Spellbook§7 recipe uses §e2 Brass Ingots§7."
				"§7Once you have 16+ Brass and complete the Brass Handshake gate below,"
				"§7return to Chapter 1's 'Mage Spellbook 🔒' quest — it will unlock."
				""
				"§a► Task: Have 16 Brass Ingots. Not consumed."
			]
			dependencies: ["000C0008"]
		}

		{
			x: 0.0d
			y: 16.0d
			shape: "hexagon"
			id: "000C000A"
			tasks: [{
				id: "000C100B"
				type: "item"
				item: "create:brass_casing"
				count: 1L
				consume_items: false
			}]
			rewards: [
				{id: "000C2011" type: "item" item: "create:precision_mechanism" count: 3}
				{id: "000C2012" type: "xp" xp: 100}
			]
			title: "Brass Handshake ✦"
			icon: "create:brass_casing"
			subtitle: "Magic meets machinery"
			description: [
				"§fYou have reached the §6Brass Age§f. This gate marks the bidirectional"
				"§fhandshake between magic and technology — and unlocks the Mage Spellbook."
				""
				"§eBrass Casing:§r"
				"§7Craft by wrapping a §6Log§7 with Brass Ingots at a crafting table."
				"§7(JEI: search 'Brass Casing' for exact recipe.)"
				"§7Brass Casings are used in every precision machine from here on."
				""
				"§eWhat this gate unlocks:§r"
				"§7  §a✦§7 §6Chapter 2.2§7 remaining quests: Precision Work, Encased Fan,"
				"§7      Funnel & Depot, Deployer, and Kitchen Automation."
				"§7  §a✦§7 §6Chapter 2.3§7: Sophisticated Storage progression."
				"§7  §a✦§7 §6Chapter 2.4§7: Create: Connected QoL machines."
				"§7  §a✦§7 §6Chapter 2.7§7: Tetra modular gear workshop."
				"§7  §a✦§7 §6Chapter 1 — Mage Spellbook 🔒§7: the magic upgrade that"
				"§7      requires Brass Ingots. Return to Ch 1 now to craft it!"
				""
				"§eThe cross-mod loop this gate represents:§r"
				"§7  Magic (Ch 1) built a Source Network → unlocked this gate."
				"§7  Technology (Ch 2) built Brass → unlocked the Mage Spellbook."
				"§7  Each system required the other's milestone to advance."
				"§7  §oThis is the design of the entire pack§7 — no branch is skippable."
				""
				"§a► Gate quest: this requires Ch 1's 'Source Network ✦' to be complete."
				"§a► Completing this retroactively unlocks Ch 1's 'Mage Spellbook 🔒'."
			]
			dependencies: ["000C0009" "000B000F"]
		}

		{
			x: -8.0d
			y: 20.0d
			id: "000C000B"
			tasks: [{
				id: "000C100C"
				type: "item"
				item: "create:precision_mechanism"
				count: 1L
				consume_items: false
			}]
			rewards: [
				{id: "000C2013" type: "item" item: "create:sequenced_gearshift" count: 1}
				{id: "000C2014" type: "xp" xp: 45}
			]
			title: "Precision Work"
			icon: "create:precision_mechanism"
			description: [
				"§fThe Precision Mechanism is Create's mid-game crafting ingredient for"
				"§feverything that moves — train engines, speed controllers, Deployers."
				"§fYou cannot progress past the Brass Age without a supply of them."
				""
				"§eHow to craft:§r"
				"§7The Precision Mechanism is crafted in the §6Mechanical Crafter§7"
				"§7(a 3×3 of individually-geared crafting blocks — build one before attempting)."
				"§7Recipe uses: Brass Casing + Iron Cogwheels + Gold Sheets + Electron Tube."
				"§7(JEI: search 'Precision Mechanism' and click the Mechanical Crafter recipe.)"
				""
				"§eAutomating Precision Mechanisms:§r"
				"§7Precision Mechanisms are always needed in quantity — never craft just one."
				"§7Build a §6Mechanical Crafter array§7 with auto-input Funnels feeding each"
				"§7slot from sorted Sophisticated Storage chests."
				"§7A 3×3 Crafter array with Funnel inputs is a Tier 1 'smart factory'."
				""
				"§eThis quest rewards a §6Sequenced Gearshift§7 — use it to program"
				"§7timed RPM sequences. Essential for train scheduling in §e2.5§7."
				""
				"§a► Task: Have 1 Precision Mechanism. Not consumed."
			]
			dependencies: ["000C000A"]
		}

		{
			x: -4.0d
			y: 20.0d
			id: "000C000C"
			tasks: [{
				id: "000C100D"
				type: "item"
				item: "create:encased_fan"
				count: 1L
				consume_items: false
			}]
			rewards: [
				{id: "000C2015" type: "item" item: "create:encased_fan" count: 2}
				{id: "000C2016" type: "xp" xp: 35}
			]
			title: "Encased Fan"
			icon: "create:encased_fan"
			description: [
				"§fThe Encased Fan blows or sucks air — and that air, when aimed at"
				"§ffire, water, or lava, processes items flowing through the airstream."
				""
				"§eCore Fan processing:§r"
				"§7• §eFan → Water stream§7 = Washing (crushed ore → extra drops)."
				"§7• §eFan → Fire / Lava§7 = Smelting (items smelt mid-air, no furnace)."
				"§7• §eFan → Soul Fire§7 = Smoking (Farmer's Delight cooked foods)."
				""
				"§eSetup for ore washing (best early value):§r"
				"§7  1. Place a §6Water Source§7 block in a 1-wide channel."
				"§7  2. Place Encased Fan at one end pointing into the channel."
				"§7  3. Connect SU to the Fan's side — higher RPM = more throughput."
				"§7  4. Drop §6Crushed Ores§7 into the stream from above via Funnel."
