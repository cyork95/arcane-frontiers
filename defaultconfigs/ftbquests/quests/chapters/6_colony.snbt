				"§7• §eMineColonies Importer§7 (KubeJS recipe) pulls specific items"
				"§7  on demand — see quest 0011000C below."
				""
				"§a► Claim the Warehouse from the Supply Chest and hold it."
			]
			dependencies: ["00110002"]
