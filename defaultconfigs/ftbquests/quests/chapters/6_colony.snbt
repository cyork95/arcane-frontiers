			}]
			rewards: [
				{id: "00112001" type: "item" item: "waystones:waystone" count: 1}
				{id: "00112002" type: "xp" xp: 100}
			]
			title: "Supply Ship"
			icon: "minecolonies:supplychest"
			subtitle: "One colony per server. Choose wisely."
			description: [
				"§6MineColonies§f lets the whole family build and run a shared colony."
				"§fBefore placing: §ediscuss the location§f with everyone."
				""
				"§e⚠ IMPORTANT: Only one colony can exist per server.§r"
				"§7• The colony site cannot be relocated after founding."
				"§7• Choose a §eflat area§7 with room to grow — at least 200×200 blocks."
				"§7• Near §ewater§7 (river/ocean) — many buildings need water access."
				"§7• Place a §eWaystone§7 (your reward) at the colony entrance first."
				""
				"§eCrafting the Supply Chest:§r"
				"§7• Check JEI — search §eminecolonies§7 to find the Supply Camp recipe."
				"§7• §ePlace it on water§7 — a Supply Ship/Camp structure spawns."
				"§7• §eEnter§7 the chest to claim the §eTown Hall§7 and §eBuilder's Hut§7 items."
				""
				"§eAll family members:§r"
				"§7• Walk to the §eTown Hall§7 and right-click → §eJoin Colony§7."
				"§7• Everyone gets colony permissions and can issue citizen orders."
				""
				"§ePrerequisite confirmed: Hearth & Home ✦ (Ch 4)§r"
				"§7Your food supply is ready. The colony can be fed from day one."
				""
				"§a► Craft or find a Supply Chest. Hold it to claim this gate."
			]
			dependencies: ["000E0016"]
		}

		{
