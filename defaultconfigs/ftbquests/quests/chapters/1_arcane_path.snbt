		// ============================================================
		// 1.1  FIRST SPARKS
		// ============================================================

		{
			x: 0.0d
			y: 0.0d
			shape: "hexagon"
			id: "000B0001"
			tasks: [{
				id: "000B1001"
				type: "item"
				item: "ars_nouveau:worn_notebook"
				count: 1L
				consume_items: false
			}]
			rewards: [
				{id: "000B2001" type: "item" item: "ars_nouveau:source_gem" count: 8}
				{id: "000B2002" type: "xp" xp: 25}
			]
			title: "The Worn Notebook"
			icon: "ars_nouveau:worn_notebook"
			subtitle: "Your arcane education begins"
			description: [
				"§6Ars Nouveau§f is the magic system at the heart of this pack."
				"§fThe Worn Notebook is your in-game guidebook — every recipe,"
				"§fglyph, ritual, and familiar has an entry inside."
				""
				"§eHow to get your Worn Notebook:§r"
				"§7• Craft §e1 Book + 1 Leather§7 in any crafting grid (shapeless)."
				"§7• Or find one in dungeon chest loot."
				"§7• This quest's §6starter reward§7 gives you Source Gems — use them"
				"§7  early to craft your first Source Jar."
				""
				"§eHow to read the Worn Notebook:§r"
				"§7• Right-click to open."
				"§7• Click a chapter header to expand it."
				"§7• Click any entry for full recipe details."
				"§7• Press §eEsc§7 or the close button to go back."
				""
				"§ePriority reading order:§r"
				"§7  1. §6Source§7 — understand this before anything else."
				"§7  2. §6Glyphs§7 — how spell components combine."
				"§7  3. §6Familiars§7 — especially Starbuncle (powers Create in Ch 5!)."
				"§7  4. §6Rituals§7 — essential for mid-game automation."
				""
				"§ePack adjustments you will not find in default guides:§r"
				"§7• Apprentice Spellbook: §e4 glyph slots§7 (default is 3)."
				"§7• Mage Spellbook: §e6 glyph slots§7."
				"§7• Archmage Spellbook: §e10 glyph slots§7."
				"§7• Source cost multiplier: §e×0.9§7 — spells cost 10% less Source."
				""
				"§a► Gate quest: completing this unlocks all Chapter 1 quests."
			]
			dependencies: []
		}

		{
			x: -8.0d
			y: 4.0d
			id: "000B0002"
			tasks: [{
				id: "000B1002"
				type: "item"
				item: "ars_nouveau:source_gem"
				count: 16L
				consume_items: false
			}]
			rewards: [
				{id: "000B2003" type: "item" item: "ars_nouveau:source_jar" count: 2}
			]
			title: "First Source"
			icon: "ars_nouveau:source_gem"
			description: [
				"§fSource is the magical energy that powers everything in Ars Nouveau."
				"§fThink of it like electricity — you generate it, store it, and spend it."
				""
				"§eWhat Source Gems are:§r"
				"§7Source Gems are compressed Source energy — physical tokens you"
				"§7can carry, trade, and use as crafting ingredients."
				""
				"§eHow to store Source:§r"
				"§7Craft a §6Source Jar§7 (Glass + Source Gem + Glass, bottom row)."
				"§7Place it on the ground. Nearby magical plants and Starbuncles"
				"§7will fill it automatically. Holds §e10,000 Source§7 per jar."
				""
				"§eHow to SPEND Source:§r"
				"§7• Casting spells draws from the nearest Source Jar in range."
				"§7• §cIf no jar is nearby, spells cost your health!§7"
				"§7• Always keep a Source Jar at base. Carry Source Gems when travelling."
				""
				"§eEarly Source generation methods:§r"
				"§7  1. §6Archwood Trees§7 (blue/purple/red bark) emit passive Source nearby."
				"§7     Find them in magical biomes — use Nature's Compass to search."
				"§7  2. §6Source Berry Bushes§7 near a Source Jar trickle Source in when ripe."
				"§7     Harvest and throw Mana Berries near a jar to convert them."
				"§7  3. §6Starbuncle familiar§7 (Ch 1.2) auto-collects gems and fills jars."
				""
				"§7This quest rewards 2 Source Jars — place them at your base immediately."
				""
				"§a► Task: Have 16 Source Gems in your inventory. They are not consumed."
			]
			dependencies: ["000B0001"]
		}

		{
			x: -3.0d
			y: 4.0d
			id: "000B0003"
			tasks: [{
				id: "000B1003"
				type: "item"
				item: "ars_nouveau:archwood_log"
				count: 16L
				consume_items: false
			}]
			rewards: [
				{id: "000B2004" type: "item" item: "ars_nouveau:source_jar" count: 1}
				{id: "000B2005" type: "xp" xp: 20}
			]
			title: "Awakened Wood"
			icon: "ars_nouveau:archwood_log"
			description: [
				"§fAwakened Wood is your first magical crafting material —"
				"§fthe foundation of every Ars Nouveau device you will build."
				""
				"§eWhere to find Archwood Trees:§r"
				"§7Archwood Trees generate in magical biomes with distinctly"
				"§7coloured bark: §bCascading§7 (blue), §eBlazin§7g (yellow),"
				"§aFlourishing§7 (green), §5Vexing§7 (purple)."
				"§7Use your §6Nature's Compass§7 and search for 'ars_nouveau' to locate them."
				""
				"§eHow to make Awakened Wood:§r"
				"§7  1. Collect §6Archwood Logs§7 from any Archwood tree."
				"§7  2. In a crafting grid: 1 Archwood Log → §dAwakened Wood Log§7"
				"§7     (shapeless conversion — one log in any slot)."
				"§7  3. Craft §dAwakened Wood Planks§7 from Awakened Logs (4 planks each)."
				""
				"§eEssential items you will craft from Awakened Wood Planks:§r"
				"§7• §6Source Jar§7 — magical energy storage."
				"§7• §6Scribe's Table§7 — where you learn glyphs from Glyph items."
				"§7• §6Artefy Table§7 — where you inscribe spells into your spellbook."
				"§7• §6Arcane Core§7 — ingredient for mid-game devices."
				"§7• §6Ritual Brazier§7 — the heart of every ritual setup."
				""
				"§eTip:§r §7Bring Bone Meal on your first Archwood expedition."
				"§7Speed-grow saplings into a full grove so you have a renewable supply."
				""
				"§a► Task: Have 16 Archwood Logs of any type. They are not consumed."
				"§7(Cascading, Blazing, Flourishing, and Vexing logs all count.)"
			]
			dependencies: ["000B0001"]
		}

		{
			x: 3.0d
			y: 4.0d
			id: "000B0004"
			tasks: [{
				id: "000B1004"
				type: "item"
				item: "ars_nouveau:glyph_projectile"
				count: 1L
				consume_items: false
			}]
			rewards: [
				{id: "000B2006" type: "item" item: "ars_nouveau:glyph_harm" count: 1}
				{id: "000B2007" type: "xp" xp: 30}
			]
			title: "Your First Glyph"
			icon: "ars_nouveau:glyph_projectile"
			description: [
				"§fGlyphs are the building blocks of every spell."
				"§fA spell is a sequence of glyphs — like a sentence where each"
				"§fword is a magical instruction."
				""
				"§eThe three glyph types:§r"
				"§7• §bForm glyphs§7 — HOW the spell travels."
				"§7  Examples: Projectile, Touch, AOE, Burst, Wave."
				"§7• §aEffect glyphs§7 — WHAT the spell does."
				"§7  Examples: Harm, Fire, Freeze, Heal, Light, Break."
				"§7• §eAugment glyphs§7 — modifies the spell's behaviour."
				"§7  Examples: Amplify, Extend Time, Pierce, Haste, Fortune."
				""
				"§eHow to craft Glyphs:§r"
				"§7  1. Build an §6Apparatus§7 (Awakened Wood Planks + Arcane Core pattern"
				"§7     shown in the Worn Notebook → Glyphs section)."
				"§7  2. Place the Apparatus with a Source Jar nearby."
				"§7  3. Put ingredients on the Apparatus pedestals as shown in JEI."
				"§7  4. The Apparatus converts ingredients → Glyph item using Source."
				""
				"§eHow to LEARN a Glyph:§r"
				"§7  1. Craft a §6Scribe's Table§7 (Awakened Wood Planks)."
				"§7  2. Right-click the Scribe's Table holding your empty spellbook."
				"§7  3. Drag the Glyph item from your inventory into the learning slot."
				"§7  4. The glyph is permanently learned — the item is consumed."
				""
				"§eStarter glyphs to prioritise:§r"
				"§7• §bProjectile§7 + §aHarm§7 = basic ranged attack."
				"§7• §bTouch§7 + §aHeal§7 = self or ally heal."
				"§7• §bTouch§7 + §aLight§7 = place a light source (no torches needed!)."
				""
				"§7This quest rewards §6Glyph: Harm§7 — combine it with Projectile."
				""
				"§a► Task: Have a Glyph: Projectile in your inventory. Not consumed."
			]
			dependencies: ["000B0001"]
		}

		{
			x: -6.0d
			y: 8.0d
			id: "000B0005"
			tasks: [{
				id: "000B1005"
				type: "item"
				item: "ars_nouveau:apprentice_spellbook"
				count: 1L
				consume_items: false
			}]
			rewards: [
				{id: "000B2008" type: "item" item: "ars_nouveau:glyph_light" count: 1}
				{id: "000B2009" type: "item" item: "ars_nouveau:source_gem" count: 12}
			]
			title: "A Touch of Magic"
			icon: "ars_nouveau:apprentice_spellbook"
			description: [
				"§fYou have Source. You have Awakened Wood. You have a glyph."
				"§fTime to cast your first real spell."
				""
				"§eCraft an Apprentice Spellbook:§r"
				"§7  Recipe: Awakened Wood Planks surrounding a Book + Source Gem"
				"§7  (check JEI — search 'Apprentice Spellbook')."
				""
				"§eBuild your first spell:§r"
				"§7  1. Craft a §6Scribe's Table§7 from Awakened Wood Planks and place it."
				"§7  2. Right-click the table while holding your Apprentice Spellbook."
				"§7  3. In the §6Glyph panel§7 on the left, click a Form glyph you have learned."
				"§7  4. Click an Effect glyph to add it after the Form."
				"§7  5. Give the spell a §ename§7 and choose a §ecolour§7."
				"§7  6. Click §6Save§7 — the spell is inscribed into your book."
				""
				"§eCasting:§r"
				"§7• Equip the spellbook in your hand."
				"§7• §eScroll§7 through your spell slots (up to 4 spells in this tier)."
				"§7• §eRight-click§7 to cast."
				"§7• Source is drawn from the nearest Source Jar in range."
				"§7• §cNo jar nearby = costs your health. Build a Source Jar first!§7"
				""
				"§ePack note — spellbook slot counts:§r"
				"§7• §6Apprentice:§7 4 spells, 4 glyph slots each."
				"§7• §6Mage:§7 6 spells, 6 glyph slots — requires Create Brass (Ch 2.2)."
				"§7• §6Archmage:§7 10 spells, 10 glyph slots — requires End Portal Key (Ch 3)."
				""
				"§7This quest rewards §6Glyph: Light§7. Build §bTouch + Light§7 as your first"
				"§7utility spell — it lights your base for free, no torches needed."
				""
				"§a► Task: Have an Apprentice Spellbook in your inventory. Not consumed."
			]
			dependencies: ["000B0002" "000B0003" "000B0004"]
		}

		{
			x: 0.0d
			y: 8.0d
			id: "000B0006"
			tasks: [{
				id: "000B1006"
				type: "item"
				item: "ars_nouveau:glyph_amplify"
				count: 1L
				consume_items: false
			}]
			rewards: [
				{id: "000B200A" type: "item" item: "ars_nouveau:glyph_pierce" count: 1}
				{id: "000B200B" type: "xp" xp: 40}
			]
			title: "Three Glyphs Deep"
			icon: "ars_nouveau:glyph_amplify"
			description: [
				"§fOne glyph makes a spell. Three glyphs make a §osystem§f."
				""
				"§eAugment glyphs — the multiplier tier:§r"
				"§7An Augment glyph placed §oafter§7 your Form + Effect changes the"
				"§7spell's power, range, or behaviour without changing what it is."
				""
				"§7• §eAmplify§7 — increases damage or effect strength."
				"§7• §eExtend Time§7 — makes lasting effects last longer."
				"§7• §ePierce§7 — projectile passes through first target and hits the next."
				"§7• §eAOE§7 (as augment after Touch) — expands the effect area."
				"§7• §eDelay§7 — spell effect triggers after a short pause."
				""
				"§eExample three-glyph spells:§r"
				"§7• §bProjectile§7 + §aHarm§7 + §eAmplify§7 = heavy bolt (great for bosses)."
				"§7• §bTouch§7 + §aHeal§7 + §eExtend Time§7 = long regeneration pulse."
				"§7• §bProjectile§7 + §aFire§7 + §eAOE§7 = fire spreads across a group of mobs."
				""
				"§eWith 4 glyph slots (your Apprentice book):§r"
				"§7Form + Effect + Augment + Augment = double-modified spell."
				"§7Try: §bProjectile§7 + §aHarm§7 + §eAmplify§7 + §eAmplify§7"
				"§7→ Expensive but devastating. Two Amplifies stack multiplicatively."
				""
				"§eSource cost scaling:§r"
				"§7A 4-glyph spell costs roughly 3× a 2-glyph spell."
				"§7With this pack's ×0.9 Source multiplier, 4-glyph spells are"
				"§7still manageable if your Source Jar network is healthy."
				""
				"§7This quest rewards §6Glyph: Pierce§7. Combine:"
				"§7§bProjectile§7 + §aHarm§7 + §eAmplify§7 + §ePierce§7 = long-range armour-piercing bolt."
				""
				"§a► Task: Have a Glyph: Amplify in your inventory. Not consumed."
			]
			dependencies: ["000B0004"]
		}

		{
			x: 7.0d
			y: 4.0d
			id: "000B0007"
			tasks: [{
				id: "000B1007"
				type: "item"
				item: "ars_nouveau:ritual_brazier"
				count: 1L
				consume_items: false
			}]
			rewards: [
				{id: "000B200C" type: "item" item: "ars_nouveau:ritual_tablet_summon_starbuncle" count: 1}
				{id: "000B200D" type: "xp" xp: 35}
			]
			title: "The Ritual Circle"
			icon: "ars_nouveau:ritual_brazier"
			description: [
				"§fRituals are large-scale magic that affect the world around you"
				"§finstead of a single target. They require a circle of candles,"
				"§fa Ritual Brazier, and a Ritual Tablet describing what to cast."
				""
				"§eHow to build a Ritual Circle:§r"
				"§7  1. Craft a §6Ritual Brazier§7 (Awakened Wood Planks + Source Gems"
				"§7     in a pattern — see Worn Notebook → Rituals for the exact recipe)."
				"§7  2. Place the Brazier on flat ground at the centre of your chosen area."
				"§7  3. Surround it with §6Candles§7 in the pattern shown on the Ritual Tablet."
				"§7     (Each Tablet shows its own pattern. Candle colour does not matter.)"
				"§7  4. Place the Ritual Tablet on the Brazier by right-clicking with it."
				"§7  5. Right-click the Brazier with a §6Source Gem§7 to start the ritual."
				""
				"§eSource cost:§r"
				"§7Rituals drain a significant amount of Source. Before any ritual:"
				"§7  • Have §e3–4 full Source Jars§7 within range of the Brazier."
				"§7  • The Brazier draws from all jars in range simultaneously."
				"§7  • If Source runs out mid-ritual, the ritual fails — place more jars!"
				""
				"§eRitual Tablets you will use most often:§r"
				"§7• §6Ritual of Summon Starbuncle§7 — summons your first familiar."
				"§7• §6Ritual of Awakening§7 — converts Archwood into Awakened Archwood."
				"§7• §6Ritual of Fertility§7 — instant-grows all crops in a wide radius."
				"§7• §6Ritual of Disintegration§7 — clears large areas of stone for mining."
				""
				"§7This quest rewards a §6Ritual Tablet: Summon Starbuncle§7."
				"§7The Starbuncle is the most important familiar in the pack — it"
				"§7auto-collects Source Gems AND powers Create machines in Ch 5."
				""
				"§a► Task: Have a Ritual Brazier in your inventory. Not consumed."
			]
			dependencies: ["000B0001"]
		}

		// ============================================================
		// 1.2  SOURCE & FAMILIARS
		// ============================================================

		{
			x: -10.0d
			y: 12.0d
			id: "000B0008"
			tasks: [{
				id: "000B1008"
				type: "item"
				item: "ars_nouveau:imbuement_chamber"
				count: 1L
				consume_items: false
			}]
			rewards: [
				{id: "000B200E" type: "item" item: "ars_nouveau:relay" count: 4}
				{id: "000B200F" type: "xp" xp: 50}
			]
			title: "Source Network"
			icon: "ars_nouveau:imbuement_chamber"
			description: [
				"§fA Source Network is an automated system that generates, transports,"
				"§fand stores magical energy — so your spells never run dry mid-dungeon."
				""
				"§eThe three layers of a Source Network:§r"
				""
				"§e1. Generation Layer:§r"
				"§7• §6Source Berry Bushes§7 near a Source Jar trickle passive Source in."
				"§7• §6Archwood Trees§7 emit Source into nearby jars when close enough."
				"§7• §6Starbuncle familiar§7 collects loose Source Gems and deposits them in jars."
				""
				"§e2. Transport Layer:§r"
				"§7• §6Relay§7 block — connects two Source Jars and transfers between them."
				"§7• §6Mana Relay§7 — longer-range transfer, used to span your base."
				"§7• Chain multiple Relays to move Source from a farm area to a work area."
				""
				"§e3. Consumption Layer:§r"
				"§7• §6Scribe's Table§7 — draws Source when you learn glyphs."
				"§7• §6Apparatus§7 — draws Source when crafting glyphs."
				"§7• §6Imbuement Chamber§7 — draws Source when infusing items."
				"§7• §6Enchanting Apparatus§7 — draws Source for enchanting rituals."
				""
				"§eThe Imbuement Chamber:§r"
				"§7The Imbuement Chamber is the crafting block where you create"
				"§7high-tier Ars Nouveau items and imbue armour with magical properties."
				"§7Recipe: Awakened Wood Planks + Source Gems pattern (see Worn Notebook)."
				""
				"§eTip:§r §7Set up one high-density Archwood grove as your 'Source Farm'."
				"§7Pipe its output via Relays to every workstation in your base."
				"§7One Starbuncle patrolling a grove of 6+ Archwood Trees fills"
				"§7a Source Jar in about 2 in-game hours passively."
				""
				"§a► Task: Have an Imbuement Chamber in your inventory. Not consumed."
			]
			dependencies: ["000B0005"]
		}

		{
			x: -5.0d
			y: 12.0d
			id: "000B0009"
			tasks: [{
				id: "000B1009"
				type: "item"
				item: "ars_nouveau:relay"
				count: 2L
				consume_items: false
			}]
			rewards: [
				{id: "000B2010" type: "item" item: "ars_nouveau:source_jar" count: 2}
			]
			title: "Mana Relay"
			icon: "ars_nouveau:relay"
			description: [
				"§fThe Relay is the 'wire' of your Source network — it carries magical"
				"§fenergy from where it is generated to where it is consumed."
				""
				"§eHow to link a Relay:§r"
				"§7  1. Hold your §6Worn Notebook§7 and right-click the §6SOURCE jar§7"
				"§7     (the one that fills up — your generation point)."
				"§7  2. Right-click the §6Relay block§7 you have placed between them."
				"§7  3. Right-click the Relay block again, then right-click the §6TARGET jar§7"
				"§7     (the one your devices draw from — your consumption point)."
				"§7  4. §aBlue particles§7 = linked and actively transferring Source."
				""
				"§eRelay types:§r"
				"§7• §6Relay§7 — standard short-range transfer, small buffer (~500 Source)."
				"§7• §6Relay Depositor§7 — pulls Source from nearby blocks into a jar."
				"§7• §6Relay Collector§7 — pulls from a linked jar into nearby blocks."
				""
				"§eRange and chaining:§r"
				"§7• Transfer range per Relay: approximately 16 blocks."
				"§7• Chain multiple Relays for longer distances."
				"§7• You can branch the chain: one generation jar can feed"
				"§7  multiple Relays going to different consumption zones."
				""
				"§eSmart base layout:§r"
				"§7  §6Generation Zone§7 (Archwood grove) → Relay → Relay"
				"§7  → splits to: §6Glyph Workshop Jar§7 + §6Ritual Altar Jar§7 + §6Combat Reserve Jar§7"
				""
				"§7Name your Source Jars with an Anvil so you know which is"
				"§7which when setting up Relay links ('Generator 1', 'Ritual Altar', etc.)."
				""
				"§a► Task: Have 2 Relay blocks in your inventory. They are not consumed."
			]
			dependencies: ["000B0005"]
		}

		{
			x: 0.0d
			y: 12.0d
			id: "000B000A"
			tasks: [{
				id: "000B100A"
				type: "checkmark"
				title: "A Starbuncle is patrolling your Source area"
			}]
			rewards: [
				{id: "000B2011" type: "item" item: "ars_nouveau:ritual_tablet_summon_starbuncle" count: 1}
				{id: "000B2012" type: "xp" xp: 45}
			]
			title: "A Familiar Friend"
			icon: "ars_nouveau:starbuncle_shard"
			description: [
				"§fFamiliars are magical companions that work for you automatically."
				"§fEach type does a different job — the right team fully automates"
				"§fyour Source generation and item logistics."
				""
				"§e★ Starbuncle§r §7— the most important familiar in this pack:"
				"§7• Collects loose Source Gems from the ground and deposits them"
				"§7  in nearby Source Jars automatically."
				"§7• Assign a patrol path: right-click with a §6Gold Stripe§7 to set"
