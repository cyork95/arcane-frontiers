			rewards: [
				{id: "000F2007" type: "item" item: "ars_nouveau:glyph_conjure_water" count: 1}
				{id: "000F2008" type: "xp" xp: 100}
			]
			title: "Glyph Press"
			icon: "ars_creo:glyph_press"
			description: [
				"§6The Glyph Press§f is Ars Creo's answer to manual glyph crafting."
				"§fVanilla Ars Nouveau glyphs are crafted one by one in the"
				"§fImbuement Chamber. The Glyph Press automates that process"
				"§fusing a §6Create Mechanical Press§f."
				""
				"§eCrafting the Glyph Press:§r"
				"§7• Search §ears_creo§7 in JEI to find the exact recipe."
				"§7• Requires §eBrass§7 (Ch 2.2), §eSource Gems§7, and §eArcane components§7."
				""
				"§eUsing the Glyph Press:§r"
				"§71. §ePlace the Glyph Press§7 on a surface."
				"§72. §ePlace a §eMechanical Press§7 directly above it."
				"§73. §eFeed ingredients§7 into the Press via §eFunnel§7 or §eConveyor§7."
				"§74. §ePower the shaft§7 connected to the Press."
				"§75. §eThe Press descends§7 and imprints the glyph onto the item."
				""
				"§eAutomation potential:§r"
				"§7• §eMechanical Arm§7 feeds ingredient stacks to the Press input."
				"§7• §eFunnel§7 below collects finished glyphs into output chest."
				"§7• §eBatch production§7 — craft 64 Glyph Projectile in minutes vs."
				"§7  the manual one-at-a-time Imbuement Chamber grind."
				""
				"§eWhy this matters:§r"
				"§7• §eGlyphs are consumable§7 — your Spellbook uses them."
				"§7  Mass production means you never run out of spell components."
				"§7• §eColony enchanting§7 (Ch 6) benefits from a steady glyph supply."
				"§7• §eSell glyphs§7 to Wandering Traders for emeralds (if configured)."
				""
				"§a► Craft and hold a Glyph Press."
			]
			dependencies: ["000F0003" "000F0004"]
		}

		{
			x: 0.0d
			y: 28.0d
			id: "000F0006"
			tasks: [{
				id: "000F1006"
				type: "checkmark"
				title: "Set up Ars Creo Source generation from Create rotation — shaft spinning fills a nearby Source Jar"
			}]
			rewards: [
				{id: "000F2009" type: "item" item: "ars_nouveau:source_jar" count: 2}
				{id: "000F200A" type: "xp" xp: 125}
			]
			title: "Source from Speed"
			icon: "ars_nouveau:source_jar"
			description: [
				"§6Ars Creo's bidirectional power§f means that not only can magic"
				"§fproduce rotation — §6rotation can produce magic.§f"
				"§fA spinning Create shaft can fill nearby Source Jars."
				""
				"§eSetup (Source generation from rotation):§r"
				"§71. §ePlace an Ars Creo Source Converter§7 (or appropriate block —"
				"§7   check JEI for the §ears_creo§7 tab) on a powered shaft."
				"§72. §ePlace Source Jars§7 within 8 blocks of the converter."
				"§73. §ePower the shaft§7 — the converter draws §eSU§7 and converts it"
				"§7   to §eSource§7 at a rate proportional to RPM."
				"§74. §eJade§7 on the Source Jar shows Source filling over time."
				""
				"§eProduction rate:§r"
				"§7• §e32 RPM§7 shaft → approximately §e200 Source/minute§7."
				"§7• §e256 RPM§7 (capped Creative Motor speed) → §e1600 Source/minute§7."
				"§7• Compare: §ePlanting Source Berry§7 + §eStarbuncle§7 = ~500 Source/hour."
				"§7  §eCreate rotation§7 is §efar faster§7 — but requires sustained mechanical power."
				""
				"§eThe magic-tech feedback loop:§r"
				"§7• §6Starbuncle Wheel§7 (magic) → §eCreate rotation§7 → §eSource Jars§7"
				"§7  → §eSpell casting§7 → §eSource depletion§7 → §eStarbuncle recharges§7"
				"§7  → §eWheel spins§7 → loop continues."
				"§7• §6Create Steam Engine§7 (tech) → §erotation§7 → §eSource Jars§7"
				"§7  → §eArs Nouveau automation§7 (Drygmy, Whirlisprig, etc.) → loop."
				""
				"§eThis is the synthesis:§r"
				"§7Magic and technology are now §eone system.§7"
				""
				"§a► Build the rotation → Source conversion. Mark done when a Source Jar fills via shaft power."
			]
			dependencies: ["000F0005"]
		}

