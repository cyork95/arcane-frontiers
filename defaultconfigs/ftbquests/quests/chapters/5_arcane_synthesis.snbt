		// ============================================================
		// 5.1  ARS CREO INTRODUCTION
		// ============================================================

		{
			x: 0.0d
			y: 0.0d
			shape: "hexagon"
			id: "000F0001"
			tasks: [{
				id: "000F1001"
				type: "item"
				item: "ars_creo:starbuncle_wheel"
				count: 1L
				consume_items: false
			}]
			rewards: [
				{id: "000F2001" type: "item" item: "ars_nouveau:source_gem" count: 32}
				{id: "000F2002" type: "xp" xp: 100}
			]
			title: "The Synthesis"
			icon: "ars_creo:starbuncle_wheel"
			subtitle: "Magic and machine share the same shaft"
			description: [
				"§6Chapter 5§f is the convergence chapter."
				"§fYou have mastered magic (Ch 1) and technology (Ch 2) separately."
				"§f§6Ars Creo§f is the mod that makes them work §etogether§f —"
				"§fArs Nouveau and Create, sharing power bidirectionally."
				""
				"§ePrerequisite:§r"
				"§7• §6Dragon Slayer ✦§7 (Ch 3) — you need End-tier progression."
				"§7• §6Archmage Spellbook§7 (Ch 1.4) — recommended before Ch 5."
				"§7• §6Power Grid ✦§7 (Ch 2) — kinetic + electric network running."
				""
				"§eWhat Ars Creo adds:§r"
				"§7• §eStarbuncle Wheel§7 — a Starbuncle-powered rotation source."
				"§7  Magic creates mechanical energy. Finally."
				"§7• §eSource from Rotation§7 — Create shafts fill nearby Source Jars."
				"§7  Mechanical energy creates magic. The loop closes."
				"§7• §eGlyph Press§7 — automates glyph crafting using Create's Sequenced"
				"§7  Assembly system."
				"§7• §eArcane Machinery§7 — Ars Nouveau spell effects on Create components."
				""
				"§eThe Starbuncle Wheel:§r"
				"§7• §eCrafting:§7 check JEI with §eU key§7 on §eStarbuncle§7 or search"
				"§7  §ears_creo§7 in the JEI item browser."
				"§7• Requires §eBrass§7 (Ch 2.2) and §eSource Gems§7 (Ch 1)."
				"§7• A Starbuncle must be assigned to it (like a Source Jar patrol)."
				""
				"§a► Craft a Starbuncle Wheel and hold it to claim this gate."
			]
			dependencies: ["000D001C"]
		}

		{
			x: 0.0d
			y: 8.0d
			id: "000F0002"
			tasks: [{
				id: "000F1002"
				type: "checkmark"
				title: "Place a Starbuncle Wheel, assign a Starbuncle to it, and confirm rotation output on a shaft"
			}]
			rewards: [
				{id: "000F2003" type: "item" item: "ars_nouveau:starbuncle" count: 2}
				{id: "000F2004" type: "xp" xp: 75}
			]
			title: "Starbuncle Power"
			icon: "ars_nouveau:starbuncle"
			description: [
				"§6The Starbuncle Wheel§f converts magical creature energy into"
				"§fpure mechanical rotation. A Starbuncle patrolling the wheel"
				"§fgenerates continuous §eSU§f without any fuel."
				""
				"§eSetting it up:§r"
				"§71. §ePlace the Starbuncle Wheel§7 anywhere with shaft clearance."
				"§72. §eConnect a shaft§7 to the wheel's output side."
				"§7   The wheel has a center axle — connect Cogwheels or Shafts directly."
				"§73. §eRight-click with a Starbuncle§7 to assign it to the wheel."
				"§7   Or use a §eRitual Tablet: Summon Starbuncle§7 near the wheel."
				"§74. §eJade§7 (block tooltip) will show RPM output when a Starbuncle is active."
				""
				"§eOutput stats:§r"
				"§7• §e1 Starbuncle§7 → §e16 RPM§7 at §e256 SU§7 continuous output."
				"§7• §eMultiple wheels§7 combine SU on the same network."
				"§7  4 wheels (4 Starbuncles) = 1024 SU — comparable to a medium windmill."
				"§7• §eAdvantage over windmills§7 — underground, weather-independent,"
				"§7  and scales with your Starbuncle farm."
				""
				"§eStarbuncle behavior:§r"
				"§7• The Starbuncle patrols between the wheel and any nearby Source Jars."
				"§7• §eDo not§7 place the wheel too far from Source Jars — Starbuncles"
				"§7  idle when out of Source range and produce no rotation."
				"§7• Keep §eSource Jars within 16 blocks§7 of each wheel."
				""
				"§eReward: 2 extra Starbuncles§r"
				"§7• Assign one to each additional wheel you build."
				"§7• Or use them in their §eSource Jar patrol§7 role (Ch 1)."
				""
				"§a► Place wheel, assign Starbuncle, connect shaft. Mark done when rotating."
			]
			dependencies: ["000F0001"]
		}

		{
			x: -6.0d
			y: 14.0d
			id: "000F0003"
			tasks: [{
				id: "000F1003"
				type: "checkmark"
				title: "Power a Create Mechanical Mixer using only Starbuncle Wheel rotation — no windmill or water wheel on the line"
			}]
			rewards: [
				{id: "000F2005" type: "xp" xp: 100}
			]
			title: "Magic Mixer ★"
			icon: "create:mechanical_mixer"
			description: [
				"§6★ Integration Quest — Create (Ch 2) + Ars Creo (Ch 5).§r"
				"§fThe Starbuncle Wheel can power any Create machine."
				"§fThe §6Mechanical Mixer§f is the first true test of magic-powered"
				"§ftechnology — brass-making by starbuncle power alone."
				""
				"§eSetup:§r"
				"§71. §eStarbuncle Wheel§7 (from previous quest) on a shaft."
				"§72. §eGearbox§7 (optional) to change direction or RPM."
				"§73. §eMechanical Mixer§7 at the end of the shaft."
				"§74. §eBasin§7 below the Mixer with ingredients."
				"§75. §eStarbuncle§7 assigned — the Mixer starts running."
				""
				"§ePower requirement:§r"
				"§7• The Mechanical Mixer needs §e4 RPM minimum§7 to start processing."
				"§7• §e1 Starbuncle§7 outputs 16 RPM — more than enough."
				"§7• §eBlaze Burner§7 in the Basin for heated recipes (Brass alloy)."
				""
				"§eWhat to mix:§r"
				"§7• §eBrass Ingots§7 (Copper + Zinc, heated) — this was Ch 2 progress,"
				"§7  now powered by magic instead of a windmill."
				"§7• §eSource Gems§7 — some Ars Creo recipes use the Mixer."
				"§7• §eArcane Alloy§7 (Ars Creo) — mixed from Brass + Source Gems."
				"§7  Needed for Glyph Press and other Ars Creo machinery."
				""
				"§eThe point:§r"
				"§7• Your §eBrass production line§7 no longer needs a windmill."
				"§7• Source Jars (Ch 1) → Starbuncles → Wheel → Mixer → Brass."
				"§7• Magic and technology have merged into one production chain."
				""
				"§a► Run a Mechanical Mixer powered only by Starbuncle Wheel rotation."
				"§a► Mix anything. Mark done when the Mixer produces output via magic power."
			]
			dependencies: ["000F0002"]
		}

		{
			x: 6.0d
			y: 14.0d
			id: "000F0004"
			tasks: [{
				id: "000F1004"
				type: "checkmark"
				title: "Connect Ars Creo rotation components to your existing Create shaft network"
			}]
			rewards: [
				{id: "000F2006" type: "xp" xp: 75}
			]
			title: "Arcane Network"
			icon: "create:shaft"
			description: [
				"§6Ars Creo§f lets you integrate magic-powered rotation into your"
				"§fexisting §6Create§f shaft network — not as a separate system,"
				"§fbut as a §enew power source on the same line§f."
				""
				"§eIntegration approach:§r"
				"§7• §eStarbuncle Wheel§7 outputs rotation via a standard axle."
				"§7• §eConnect§7 that axle to your existing §eCreate shaft network§7"
				"§7  using §eCogwheels§7, §eGearboxes§7, or direct §eShaft§7 connections."
				"§7• The wheel adds its §e256 SU§7 to the network's total stress budget."
				""
				"§eArs Creo connectors:§r"
				"§7• §eArcane Shaft§7 (if available) — magical conductor that transmits"
				"§7  rotation through Source-charged blocks."
				"§7• §eStarbuncle Wheel direct§7 — simplest: axle from wheel to main network."
				"§7• §eThroughput§7 — each wheel can feed into a §eLarge Cogwheel§7"
				"§7  to double torque at half RPM, useful for high-SU machines."
				""
				"§eMixed power grid:§r"
				"§7• §eWater Wheel§7 (base) + §eSteam Engine§7 (Ch 2.5) + §eStarbuncle Wheel§7"
				"§7  all feeding the same shaft network is perfectly valid."
				"§7• §eTotal SU§7 = sum of all sources. §eRPM§7 = determined by the"
				"§7  dominant source if connected directly."
				"§7• §eUse Clutches§7 (Ch 2.4) to isolate sections of the network"
				"§7  so magic power only reaches magic-appropriate machines."
				""
				"§eTip:§r"
				"§7• §eJade§7 shows the SU contribution of each shaft segment."
				"§7  Hover the Starbuncle Wheel to see its real-time contribution."
				""
				"§a► Connect a Starbuncle Wheel shaft to any existing Create machine network."
				"§a► Mark done when the wheel contributes SU to the grid."
			]
			dependencies: ["000F0002"]
		}

		{
