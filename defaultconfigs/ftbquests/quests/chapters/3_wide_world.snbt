			]
			title: "Friends & Foes"
			icon: "friendsandfoes:moobloom_flower"
			description: [
				"§6Friends & Foes§f adds mobs from Minecraft community mob votes"
				"§fthat didn't make it into vanilla — they now exist in Arcane Frontiers."
				""
				"§eMobs added by Friends & Foes:§r"
				"§7• §eMoobloom§7 (Flower Forests) — flower-covered cow variant, drops"
				"§7  §eMoobloom Petals§7 used in dyes and Farmer's Delight recipes."
				"§7  §eInteract: right-click with shears§7 to harvest petals."
				"§7• §eCopper Golem§7 (rare, constructed) — buildable mob from copper."
				"§7  §eInteract: build with copper blocks and lightning rod§7."
				"§7• §eGlare§7 (dark forests, caves) — passive, points toward dark spots."
				"§7  §eInteract: follow one§7 to discover unlit areas worth torching."
				"§7• §eIceologer§7 (Snowy biomes) — hostile mage, throws ice chunks."
				"§7  Kill for §eIce Shard§7 drops (Ch 7 Twilight Forest gear material)."
				"§7• §eWildfire§7 (Nether) — boss-tier mob with fire shields."
				"§7  Kill for §eFireborn Scales§7 (fire resistance gear component)."
				""
				"§eEasiest way to complete this quest:§r"
				"§7• Find a §eMoobloom§7 in a Flower Forest and shear it for petals."
				""
				"§a► Interact with, tame, trade with, or shear any F&F mob. Mark done."
			]
			dependencies: ["000D0008" "000D0009"]
		}

