	quests: [

		// ============================================================
		// 3.1  BIOME DISCOVERY
		// ============================================================

		{
			x: 0.0d
			y: 0.0d
			shape: "hexagon"
			id: "000D0001"
			tasks: [{
				id: "000D1001"
				type: "item"
				item: "naturesscompass:natures_compass"
				count: 1L
				consume_items: false
			}]
			rewards: [
				{id: "000D2001" type: "item" item: "waystones:warp_stone" count: 2}
				{id: "000D2002" type: "xp" xp: 25}
			]
			title: "Compass of Biomes"
			icon: "naturesscompass:natures_compass"
			subtitle: "The world is much larger than it looks"
			description: [
				"§6Nature's Compass§f lets you search for any biome — including all"
				"§fthe new §6Terralith§f biomes — by name."
				""
				"§eCrafting:§r"
				"§7• §eCompass§7 + §eEmerald§7 in a crafting table (shapeless)."
				"§7• Your starter Compass from Chapter 0 becomes this once upgraded."
				""
				"§eHow to use it:§r"
				"§7• §eRight-click§7 to open the biome search UI."
				"§7• Type a biome name (e.g. §6volcanic_peaks§7, §6moonlight_grove§7)."
				"§7• Click §eSearch§7 — the compass needle will point toward the nearest"
				"§7  instance of that biome."
				"§7• Distance estimate appears below the needle."
				""
				"§eTerralith biomes to know:§r"
				"§7• §eVolcanic Peaks§7 — lava flows, basalt, extreme heat."
				"§7• §eMoonlight Grove§7 — rare glowing forest, beautiful builds."
				"§7• §eIce Spikes§7 variants — useful for Snowflake Obsidian (Ch 2)."
				"§7• §eAlpine Meadow§7 — flat, high elevation — great for windmills."
				""
				"§a► Craft a Nature's Compass to unlock all 3.1 biome discovery quests."
			]
			dependencies: []
		}

		{
			x: -8.0d
			y: 8.0d
			id: "000D0002"
			tasks: [{
				id: "000D1002"
				type: "checkmark"
				title: "Visit 5 distinct Terralith biomes and mark each with F3 screenshots or Waystones"
			}]
			rewards: [
				{id: "000D2003" type: "xp" xp: 50}
			]
			title: "Terralith Traveler"
			description: [
				"§6Terralith§f completely overhauls the Overworld biome distribution."
				"§fInstead of vanilla's flat plains and forests you will encounter:"
				""
				"§7• §eCascading Moonlight Grove§7 — rare glowing mushroom-blue forest."
				"§7• §eCaldera§7 — sunken volcanic crater with obsidian and lava lakes."
				"§7• §eAlpine Highlands§7 — snow-capped meadows perfect for windmills."
				"§7• §eScarlet Mountains§7 — red stone cliffs, excellent mineral exposure."
				"§7• §eMirage Isles§7 — floating islands with unusual vegetation."
				"§7• §eFrozen Cliffs§7 and §eFrosted Taiga§7 — snow variants with packed ice."
				""
				"§eTips for finding biomes:§r"
				"§7• Use §eNature's Compass§7 (previous quest) to search by name."
				"§7• Press §eF3§7 to see your current biome in the top-left debug info."
				"§7• §eJade§7 shows the biome name when you press F3+H and look at air."
				""
				"§ePlacing Waystones:§r"
				"§7• Each biome is worth naming and marking with a Waystone."
				"§7• The family can then warp back to farm rare biome resources."
				""
				"§a► Visit 5 different Terralith biomes. Mark done when complete."
			]
			dependencies: ["000D0001"]
		}

		{
			x: 0.0d
			y: 8.0d
			id: "000D0003"
			tasks: [{
				id: "000D1003"
				type: "checkmark"
				title: "Discover a rare Terralith biome: Volcanic Peaks, Moonlight Grove, Mirage Isles, Caldera, or equivalent"
			}]
			rewards: [
				{id: "000D2004" type: "item" item: "waystones:waystone" count: 1}
				{id: "000D2005" type: "xp" xp: 50}
			]
			title: "Strange New Lands"
			description: [
				"§6Terralith's rarest biomes§f don't appear on most journeys."
				"§fYou have to search for them specifically — which is why you have a compass."
				""
				"§eRare biomes worth hunting:§r"
				"§7• §eVolcanic Peaks§7 — active lava geysers, unique basalt formations."
				"§7  Tip: §eBlackstone§7 generates here in huge quantities."
				"§7• §eMoonlight Grove§7 — glowing blue forest, very rare, beautiful builds."
				"§7  Tip: §eMoonlight Stones§7 make extraordinary floors and paths."
				"§7• §eMirage Isles§7 — floating islands above warm ocean, disorienting terrain."
				"§7• §eCaldera§7 — sunken volcanic bowl with lava rivers."
				"§7• §eAbyssal Chasm§7 — deep ocean variant with unusual deep-sea caves."
				""
				"§eStrategy:§r"
				"§7• Use Nature's Compass → type the biome name → fly/boat toward it."
				"§7• When you arrive, §eplace a Waystone immediately§7 — rare biomes are"
				"§7  hard to relocate once you leave."
				""
				"§eReward: 1 Waystone§r"
				"§7• Extra Waystone for your rare biome base camp."
				""
				"§a► Find any one of the listed rare biomes. Mark done on arrival."
			]
			dependencies: ["000D0002"]
		}

		{
			x: -8.0d
			y: 16.0d
			id: "000D0004"
			tasks: [{
				id: "000D1004"
				type: "item"
				item: "waystones:waystone"
				count: 3L
				consume_items: false
			}]
			rewards: [
				{id: "000D2006" type: "xp" xp: 40}
			]
			title: "Wayfinder"
			icon: "waystones:waystone"
			description: [
				"§6Waystones§f are the family's fast-travel network."
				"§fPlace them at key locations and everyone on the server can warp between them."
				""
				"§ePlacing a Waystone:§r"
				"§7• Craft: §e2 Stone Bricks + 2 Flint + 1 Iron Ingot§7 (shaped, 3-high pillar)."
				"§7• Place the Waystone block. Right-click to §ename it§7."
				"§7• The name appears on everyone's teleport list immediately."
				""
				"§eSuggested placements for 3 Waystones:§r"
				"§71. §eHome Base§7 — right outside your main base entrance."
				"§72. §eColony§7 — at the Town Hall when the colony is founded (Ch 6)."
				"§73. §eBiome Outpost§7 — at your rare biome discovery camp."
				""
				"§eWarp Stone vs Waystone:§r"
				"§7• §eWarp Stone§7 (your reward from quest 1) — portable, use anywhere,"
				"§7  5-minute cooldown."
				"§7• §eWaystone§7 — stationary, free to teleport to from any other Waystone"
				"§7  or Warp Stone, no cooldown penalty for destination."
				""
				"§a► Have 3 Waystones in your inventory at once (don't need to place them)."
			]
			dependencies: ["000D0002"]
		}

		{
			x: 0.0d
			y: 16.0d
			id: "000D0005"
			tasks: [{
				id: "000D1005"
				type: "checkmark"
				title: "Find a village and upgrade it using Create: Dynamic Village"
			}]
			rewards: [
				{id: "000D2007" type: "xp" xp: 50}
			]
			title: "Dynamic Village"
			icon: "minecraft:bell"
			description: [
				"§6Create: Dynamic Village§f lets you build Create-powered infrastructure"
				"§finside existing villages, upgrading villagers' workstations with"
				"§fmachinery and improving their trades."
				""
				"§eHow it works:§r"
				"§7• Find a village with a Terralith or vanilla biome."
				"§7• Create: Dynamic Village adds new workstation block types near"
				"§7  villager houses. Some villagers will retrain to new Create-based jobs."
				"§7• Placing §eCreate§7 machines (Mechanical Press, Mixer, Fan) near"
				"§7  the village center may trigger §edynamic upgrades§7 to nearby workstations."
				""
				"§eWhat upgrades become available:§r"
				"§7• §eBrass Merchant§7 — trades Brass Ingots and Precision Mechanisms."
				"§7• §eSteam Supplier§7 — trades Steam Whistles and Boiler parts."
				"§7• §eKinetic Engineer§7 — trades Cogs, Shafts, and Encased Fans."
				""
				"§eTips:§r"
				"§7• Use Nature's Compass to search for §ePlains§7 or §eSavanna§7 — villages"
				"§7  are most common there in Terralith."
				"§7• Set up a Waystone in the village to return easily."
				""
				"§a► Find a village and place at least one Create machine near the center."
				"§a► Mark done when a Dynamic Village UI or upgraded workstation appears."
			]
			dependencies: ["000D0004"]
		}

		{
			x: 8.0d
			y: 12.0d
			id: "000D0006"
			tasks: [{
				id: "000D1006"
				type: "item"
				item: "minecraft:filled_map"
				count: 3L
				consume_items: false
			}]
			rewards: [
				{id: "000D2008" type: "xp" xp: 60}
			]
			title: "Cartographer's Dream ★"
			icon: "minecraft:filled_map"
			description: [
				"§6Filled Maps§f become your atlas of the world."
				"§fWith §6Terralith§f rewriting the landscape, the maps you create"
				"§fare unlike anything in vanilla."
				""
				"§eCrafting a Filled Map:§r"
				"§7• Craft §eEmpty Map§7 (8 Paper + 1 Compass) then §eright-click to fill it."
				"§7• Or buy maps from §eCartographer Villagers§7 (Dynamic Village upgrade)."
				""
				"§eTips for three good maps:§r"
				"§71. §eHome region§7 — center on your base so you always know what's near."
				"§72. §eRare biome§7 — document where you found Moonlight Grove or Volcanic Peaks."
				"§73. §eColony area§7 — scout the colony build site before placing the Supply Ship."
				""
				"§eItem Frames + Maps:§r"
				"§7• Place §eItem Frame§7 on a wall, then place a filled map inside."
				"§7• Multiple frames next to each other create a large wall map."
				"§7• §eGlow Item Frame§7 (from glowing squid) shows the map in the dark."
				""
				"§e★ Integration note:§r"
				"§7• This quest satisfies both the exploration track (3.1) and the"
				"§7  building/home track (4.1). It bridges both chapters."
				""
				"§a► Have 3 Filled Maps in your inventory simultaneously."
			]
			dependencies: ["000D0003" "000D0005"]
		}

		// ============================================================
		// 3.2  ALEX'S MOBS & CAVES
		// ============================================================

		{
			x: -4.0d
			y: 24.0d
			id: "000D0007"
			tasks: [{
				id: "000D1007"
				type: "checkmark"
				title: "Obtain and read the Alex's Mobs Field Guide (craft or find in world)"
			}]
			rewards: [
				{id: "000D2009" type: "xp" xp: 40}
			]
			title: "Field Guide"
			icon: "alexsmobs:field_guide"
			description: [
				"§6Alex's Mobs§f adds over 80 new creatures to the world —"
				"§feach with unique behaviors, drops, and interactions."
				"§fThe §eField Guide§f is your bestiary."
				""
				"§eGetting the Field Guide:§r"
				"§7• §eCraft:§7 §eBook§7 + §eFeather§7 + §eAny Alex's Mob drop§7 (shapeless)."
				"§7• Or find one in a chest in any structure where Alex's Mobs appear."
				""
				"§eHow to use it:§r"
				"§7• Right-click to open. Browse entries by biome tab."
				"§7• Each entry shows: where the mob spawns, what it drops, whether it's"
				"§7  hostile/neutral/passive, and special interactions."
				"§7• §eEntries unlock progressively§7 as you encounter each mob."
				""
				"§eHighlight mobs by biome:§r"
				"§7• §ePlains§7 — Bison, Capuchin Monkeys, Roadrunners."
				"§7• §eForest§7 — Raccoons, Hammerhead Sharks, Laviathans in rivers."
				"§7• §eDesert§7 — Cachalot Whales, Potoo, Catfish."
				"§7• §eCaves§7 — Cave Centipedes, Mimicubes (treasure chest mimics!)."
				"§7• §eOcean§7 — Whale Sharks, Sunfish, Leafy Sea Dragons."
				""
				"§a► Obtain the Field Guide. Mark done once you have it in hand."
			]
			dependencies: ["000D0001"]
		}

		{
			x: 0.0d
			y: 28.0d
			id: "000D0008"
			tasks: [{
				id: "000D1008"
				type: "checkmark"
				title: "Kill 3 different species of Alex's Mobs creatures"
			}]
			rewards: [
				{id: "000D200A" type: "xp" xp: 60}
			]
			title: "Big Game Hunter"
			icon: "alexsmobs:bison_fur"
			description: [
				"§6Alex's Mobs§f creatures drop unique materials used in recipes"
				"§fthroughout the pack. Getting comfortable fighting them early"
				"§fpays off in Ch 4 (cooking) and Ch 7 (gear)."
				""
				"§eGood starter targets:§r"
				"§7• §eBison§7 (Plains) — drops §eBison Fur§7, used for warm armor."
				"§7  Neutral; attacks only when provoked."
				"§7• §eCascade§7 (River) — small, easy, drops §eCascade Scale§7."
				"§7• §eRaccoon§7 (Forest edge) — passive but drops §eRaccoon Tail§7."
				"§7• §eMoose§7 (Taiga) — neutral, large, drops §eMoose Antler§7 for tools."
				"§7• §eManta Ray§7 (Ocean) — passive, drops §eManta Ray Fin§7."
				""
				"§eWarning mobs to avoid early:§r"
				"§7• §eMimicube§7 — looks like a chest, very aggressive when approached."
				"§7• §eBig Squid§7 — ocean, can pull you under water."
				"§7• §eElectric Eel§7 — stuns and deals heavy damage in water."
				""
				"§eCooking integration:§r"
				"§7• Many Alex's Mobs drops are §eFarmer's Delight§7 ingredients."
				"§7  See Ch 4 for Central Kitchen recipes using exotic meats."
				""
				"§a► Kill any 3 distinct Alex's Mobs species. Mark done when complete."
			]
			dependencies: ["000D0007"]
		}

		{
			x: 8.0d
			y: 24.0d
			id: "000D0009"
			tasks: [{
				id: "000D1009"
				type: "checkmark"
				title: "Discover an Alex's Caves biome or structure underground"
			}]
			rewards: [
				{id: "000D200B" type: "xp" xp: 60}
			]
			title: "Underground Wonders"
			icon: "alexscaves:xenomite_crystal"
			description: [
				"§6Alex's Caves§f adds entirely new underground biomes, each with"
				"§funique blocks, creatures, and resources."
				""
				"§eCave biomes to find:§r"
				"§7• §eFossil Grove§7 — ancient bones and petrified wood, warm amber light."
				"§7  Contains §eFossil§7 blocks and unique §eExhumed§7 mob type."
				"§7• §eAbyssal Chasm§7 — deep flooded cave, bioluminescent creatures."
				"§7  §eAbyssal Kelp§7 grows here — ingredient for advanced potions."
				"§7• §eXenomite Caves§7 — glowing green crystals, radioactive biome."
				"§7  §eXenomite Crystal§7 is a crafting material for tech upgrades."
				"§7• §eMagnetic Caves§7 — iron debris and lodestones everywhere."
				"§7  Magnetic blocks affect player movement — disorienting and fun."
				"§7• §ePrimordial Caves§7 — prehistoric, giant prehistoric mushrooms."
				""
				"§eHow to find them:§r"
				"§7• Dig deep (y = -30 to -60) and explore widely."
				"§7• Alex's Caves biomes replace portions of the deep layer."
				"§7• Use §eNight Vision§7 potions — many biomes are very dark."
				""
				"§aTip: Bring a Waystone to mark cave entrances you want to revisit."
				"§a► Mark done when you enter any Alex's Caves biome or find its structure."
			]
			dependencies: ["000D0006"]
		}

		{
