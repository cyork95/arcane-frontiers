		{
			x: 14.0d
			y: 40.0d
			shape: "hexagon"
			id: "000D000E"
			tasks: [{
				id: "000D100E"
				type: "checkmark"
				title: "Activate the End Portal — insert all 12 Eyes of Ender into the frame"
			}]
			rewards: [
				{id: "000D2012" type: "item" item: "minecraft:chorus_fruit" count: 16}
				{id: "000D2013" type: "xp" xp: 200}
			]
			title: "End Portal Key ⊕"
			subtitle: "Magic and machine, combined"
			description: [
				"§6This is the central gate of Arcane Frontiers.§r"
				"§fTo open The End, you must have mastered both pillars:"
				"§fmagic (Ch 1 Arcane Automation) and technology (Ch 2 Power Grid)."
				"§fNeither alone is enough."
				""
				"§ePrerequisites:§r"
				"§7• §6Ch 1 — Arcane Automation ✦§7 completed."
				"§7  This means you have a Starbuncle automation network, familiars,"
				"§7  and advanced spells — including the Bookwyrm."
				"§7• §6Ch 2 — Power Grid ✦§7 completed."
				"§7  This means you have Create: New Age power sources (solar, wind,"
				"§7  electric motor) running alongside your kinetic network."
				""
				"§eActivating the End Portal:§r"
				"§7• You need §e12 Eyes of Ender§7 total. We gave you 12 from the last quest."
				"§7• Right-click §eeach of the 12 portal frame blocks§7 to insert an eye."
				"§7• When all 12 are filled the portal activates. §eStand clear§7 of the"
				"§7  center — the portal opens violently."
				""
				"§eUnlocks:§r"
				"§7• §6Ch 3.5 — The End§7 quests (this chapter, below)."
				"§7• §6Ch 1 — Archmage Spellbook 🔒§7 — the final magic upgrade."
				""
				"§eReward: 16 Chorus Fruit§r"
				"§7• Chorus Fruit teleports you randomly up to 8 blocks."
				"§7• Combine with Popped Chorus Fruit in a Blast Furnace → §ePurpur Block§7."
				"§7• Needed for End-tier builds and Ars Nouveau Archmage rituals."
				""
				"§a► Insert all 12 Eyes of Ender into the End Portal frame. Mark done."
			]
			dependencies: ["000D000D" "000B0015" "000C0024"]
		}

