				type: "checkmark"
				title: "Discover and enter an Incendium biome in the Nether"
			}]
			rewards: [
				{id: "000D2015" type: "xp" xp: 75}
			]
			title: "Incendium Explorer"
			icon: "incendium:glow_torch"
			description: [
				"§6Incendium§f transforms the Nether from a flat crimson landscape"
				"§finto a layered, varied hellscape with six distinct biomes."
				""
				"§eIncendium biomes:§r"
				"§7• §eToxic Heap§7 — acid green biome, poisonous slimes, corroded stone."
				"§7  §eDrop: Sludge§7 — ingredient for corrosion-resistant gear coatings."
				"§7• §eEmber Barrens§7 — flat, glowing cinders, ember particles."
				"§7  §eDrop: Cinder§7 — fire-starting material, better than Flint & Steel."
				"§7• §eQuartz Flats§7 — expanded Quartz Fields, crystalline formations."
				"§7  §eDrop: Quartz Geode§7 — large Quartz deposits, useful for Ch 2."
				"§7• §eNether Jungle§7 — dense nether foliage, Blaze variants lurk here."
				"§7• §eDungeon of Souls§7 — Incendium structure, brutal loot table."
				"§7• §eInfernal Dunes§7 — sandy Nether floor, buried ruins below."
				""
				"§eNavigation tip:§r"
				"§7• Use §eNature's Compass§7 — it works in the Nether and can search"
				"§7  for Incendium biome names (§etoxic_heap§7, §eember_barrens§7, etc.)."
				""
				"§a► Enter any Incendium biome in the Nether. Mark done on arrival."
			]
			dependencies: ["000D000F"]
		}

