				{id: "000D200E" type: "xp" xp: 75}
			]
			title: "Dungeon Delver"
			icon: "minecraft:chest"
			description: [
				"§6YUNG's Better Dungeons§f replaces vanilla dungeon rooms with"
				"§ffull multi-room dungeon complexes. §6Dungeons & Taverns§f adds"
				"§fentirely new structures across the overworld."
				""
				"§eStructures to find and clear:§r"
				"§7• §eYUNG's Catacombs§7 — underground labyrinth, multiple floors."
				"§7  Spawners on every level. Loot chests contain enchanted books."
				"§7• §eYUNG's Forbidden Castle§7 — surface structure, 5+ floors."
				"§7  Contains boss room with boosted loot table."
				"§7• §eYUNG's Ruins§7 — scattered surface ruins with buried chests."
				"§7• §eDungeons & Taverns Tavern§7 — above-ground, safe to enter."
				"§7  Buy custom trades from the Innkeeper villager inside."
				"§7• §eDungeons & Taverns Dungeon§7 — underground, multi-room."
				"§7  Best loot in the pack outside of boss drops."
				""
				"§eCombat tips:§r"
				"§7• Bring at least §eIron armor§7 and §e16 cooked food§7."
				"§7• §eArs Nouveau§7 shield spell (Orbit + Shield) blocks spawner mobs."
				"§7• §eTetra§7 upgraded pickaxe destroys spawners in 2 hits."
				"§7• §eTorches§7 — light every room as you clear it to prevent respawns."
				""
				"§a► Clear at least one room of a YUNG's or D&T dungeon. Mark done."
			]
			dependencies: ["000D0008"]
		}

